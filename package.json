{
  "name": "site-assistant-widget",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --base=/moj.chatbot.backend/ && vite build --config vite.embed.config.ts",
    "preview": "vite preview",
    "serve:dist": "node scripts/serve-dist.mjs",
    "check": "tsc -b --pretty false",
    "lint": "npm run check",
    "test": "node --test tests/widget-contract.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "animejs": "^4.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.1.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.14"
  }
}
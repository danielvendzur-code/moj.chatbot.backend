{
  "name": "site-assistant-widget",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --base=/moj.chatbot.backend/ && vite build --config vite.embed.config.ts",
    "preview": "vite preview",
    "serve:dist": "node scripts/serve-dist.mjs",
    "check": "tsc -b --pretty false",
    "lint": "npm run check",
    "test": "node --test tests/widget-contract.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "animejs": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^5.1.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}